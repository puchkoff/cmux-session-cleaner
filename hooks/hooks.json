            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/scripts/prune_cmux_sessions.py 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
